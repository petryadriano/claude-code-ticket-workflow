# Generate with: node build-env.mjs <environmentName> <user> [cloudEnv] [--with=<domain>]
#   (needs valid cloud credentials — refresh them only if a call fails; prompts your password). Run ONCE per workspace — every ticket reuses it.
# NEVER commit .env — it holds your live credentials. It is gitignored; only THIS .env.example is committed.

# --- baseline (every ticket) ---
E2E_API_URL=http://localhost:8080           # YOUR local API (working-tree code under test)
E2E_REMOTE_API_URL=                         # deployed remote API — remoteApi fixture (merged-code regressions only)
E2E_AUTH_URL=                               # auth API (deployed works: token lands in the shared auth DB)
E2E_ENVIRONMENT=                            # target environment name — mine related tickets' comments for the right one
E2E_USER=
E2E_PASSWORD=
E2E_TOKEN=                                  # alternative to user/password: pre-acquired token
E2E_IMPERSONATE=                            # per-ticket login identity (grants live there)
E2E_DB_CONNECTION=                          # target-environment DB — SELECT for assertions; WRITES need user approval

# --- example UI specs (only for tickets with a UI AC; fixtures/example-app.ts) ---
# The specs drive whatever serves the UI, pointed at YOUR local API (see your start-stack docs):
#   dev server (default):  E2E_UI_URL=http://localhost:3000   E2E_UI_PATH=/{recordId}/{versionId}
#   app host (Docker):     E2E_UI_URL=http://localhost:8090   E2E_UI_PATH=/{environment}/App/{recordId}/{versionId}
# E2E_UI_URL=
# E2E_UI_PATH=
# E2E_UI_ENV=REMOTE                          # UI env-map key the auth param uses

# --- domain-specific (ONLY for tickets touching that area; added by --with=<domain>) ---
# example-domain (import fixtures/example-app.ts): callback scenarios for an external data source
# E2E_EXAMPLE_CALLBACK_KEY=                   # Common:ExampleIntegration:CallbackApiAccessKey
